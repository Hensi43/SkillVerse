# Server configuration
PORT=5000
NODE_ENV=development

# Database configuration
MONGO_URI=mongodb://localhost:27017/skillverse

# Redis config (for BullMQ / Socket.io scale, optional in local fallback mode)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT secrets
JWT_SECRET=skillverse-super-secret-access-token-key-2026
JWT_REFRESH_SECRET=skillverse-super-secret-refresh-token-key-2026

# Local Dev Mocks
MOCK_OTP=true

# Storage Provider Strategy: 'local' (Mac Disk) or 's3' (Production cloud)
STORAGE_PROVIDER=local
UPLOAD_DIR=uploads

# AWS S3 Configurations (Required only if STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=skillverse-assets

# AI services (Required for real voice evaluation, falling back to mock heuristic if empty)
OPENAI_API_KEY=
